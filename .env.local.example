NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# Google Analytics 4 측정 ID (예: G-XXXXXXXXXX). 비워두면 GA 태그가 아예 렌더링되지 않는다.
# 로컬 개발 데이터가 실서비스 통계에 섞이지 않도록 로컬에서는 비워두는 것을 권장.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_SITE_URL=https://to-teacher.com

# 음성 녹음 동의 기록을 구글 시트에 적재하기 위한 서버 전용(비-NEXT_PUBLIC) env.
# 구글 시트를 만들고, 서비스 계정 이메일을 해당 시트의 "편집자"로 공유해야 한다.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=
GOOGLE_CONSENT_SHEET_ID=
GOOGLE_CONSENT_SHEET_RANGE=Consent!A:E

# 만족도 설문 기록을 구글 시트에 적재하기 위한 env. 서비스 계정은 위와 동일한 것을 재사용해도 되지만
# 시트는 별도로 만들어 서비스 계정 이메일을 "편집자"로 공유해야 한다.
GOOGLE_SURVEY_SHEET_ID=
GOOGLE_SURVEY_SHEET_RANGE=Survey!A:G
